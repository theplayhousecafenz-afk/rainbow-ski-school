# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode keys to start)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...
# Development: onboarding@resend.dev  |  Production: lessons@rainbowskischool.co.nz
EMAIL_FROM=onboarding@resend.dev
# Admin notification recipient
ADMIN_EMAIL=admin@example.com

# Admin dashboard password
ADMIN_PASSWORD=change-me-before-deploying

# Cron job secret (sent as Authorization: Bearer <secret> from Supabase Edge Function)
CRON_SECRET=some-long-random-string

# Twilio SMS — leave blank to disable; fill in to activate
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App base URL (used in email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
